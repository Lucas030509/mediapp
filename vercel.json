{
    "buildCommand": "vercel build",
    "installCommand": "npm install",
    "rewrites": [
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "(?<tenant>.*).tuplataforma.com"
                }
            ],
            "destination": "/tenant/:tenant/:path*"
        }
    ]
}